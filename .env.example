# Environment variables for homelab Docker Compose setup
# Copy this file to .env and adjust values as needed.

# Convenience profile for the full main stack (infra + apps)
# Keep this only if you want docker compose to target the full stack by default.
# setup-dev.sh generates some app keys automatically, but passwords and external credentials still need attention.
COMPOSE_PROFILES=all

# Container timezone used across compose stacks
TZ=Europe/Copenhagen

# Domain used for all services (default: traefik.me)
# Set to your custom domain for production with automatic TLS certificates.
DOMAIN=traefik.me

# Let's Encrypt ACME contact email for production certificates
ACME_EMAIL=

# Cloudflare DNS API token for production DNS-01 challenges
# Required permissions: Zone:Read and DNS:Edit.
CF_DNS_API_TOKEN=

# Dockhand bootstrap data directory on the Docker host.
# Keep the default matching path when deploying stacks with relative bind mounts.
# DOCKHAND_DATA_DIR=/opt/dockhand

# Host port used for AdGuard DNS. Keep 1053 in development to avoid conflicts
# with system DNS on port 53. Set to 53 on dedicated hosts.
ADGUARD_DNS_PORT=1053

# Netbird IP ranges for admin/user segregation (optional)
# Format: comma-separated list of CIDR ranges
# ADMIN_IPS=100.64.0.10/32,100.64.0.11/32  # Your admin devices
# USER_IPS=100.64.0.0/24                   # All VPN users

# Optional: App database overrides (safe defaults are in compose)
# Password generator in the dev shell: mkpasswd -l 32 -s 1
# Secret generator: openssl rand -base64 32
# IMMICH_DB_USERNAME=immich
# IMMICH_DB_PASSWORD=
# IMMICH_DB_DATABASE_NAME=immich
# PAPERLESS_DBNAME=paperless
# PAPERLESS_DBUSER=paperless
# PAPERLESS_DBPASS=
# PAPERLESS_ADMIN_PASSWORD=
# PAPERLESS_SECRET_KEY=
# LISTMONK_db__user=listmonk
# LISTMONK_db__password=
# LISTMONK_db__database=listmonk

# Karakeep / Meilisearch
# NEXTAUTH_SECRET=
# MEILI_MASTER_KEY=
# KARAKEEP_OPENAI_API_KEY=
# Leave these unset in local development to keep Karakeep password auth enabled.
# Set these in production only when you want optional OIDC sign-in.
# KARAKEEP_OAUTH_WELLKNOWN_URL=https://idp.example.com/.well-known/openid-configuration
# KARAKEEP_OAUTH_CLIENT_ID=
# KARAKEEP_OAUTH_CLIENT_SECRET=
# KARAKEEP_OAUTH_PROVIDER_NAME=OIDC

# RustFS
RUSTFS_ACCESS_KEY=rustadmin
RUSTFS_SECRET_KEY=rustadmin

# Media VPN (required for Gluetun + ProtonVPN download automation)
# OPENVPN_USER=
# OPENVPN_PASSWORD=
# VPN_SERVER_COUNTRIES=Netherlands

# Speedtest Tracker (or export via .envrc)
# App key generator: openssl rand -base64 32
# SPEEDTEST_APP_KEY=
